# Google AI API key (required) — get one at https://aistudio.google.com/apikey
# Set either GEMINI_API_KEY or GOOGLE_API_KEY (both are checked automatically).
GEMINI_API_KEY=your-api-key-here
# GOOGLE_API_KEY=your-api-key-here

# Override the default Gemini model (optional).
# EDGE_AGENT_MODEL=gemini-2.5-flash

# Disable TLS certificate verification (dev/local only — never use in production).
# EDGE_AGENT_VERIFY_SSL=false
